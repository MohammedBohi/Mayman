# Server
PORT=3000

# CORS — frontend allowed origin (comma-separated for multiple values not supported here, see index.js)
FRONTEND_URL=http://localhost:8080

# PostgreSQL connection string
# Local example:    postgresql://user:password@localhost:5432/mayman
# Railway/prod:     postgresql://user:password@host:port/database (SSL required)
DATABASE_URL=postgresql://user:password@localhost:5432/mayman

# JWT — generate a secure random string (e.g. `openssl rand -hex 64`)
JWT_SECRET=replace_with_a_long_random_string

# Brevo (transactional emails via REST API)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@example.com

# Admin email address (recipient of new-booking notifications)
ADMIN_EMAIL=admin@example.com
